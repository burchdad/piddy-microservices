# .env.example - Piddy Microservices Configuration Template

# Copy this file to .env and fill in your values
# DO NOT commit .env to git - it contains secrets

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://piddy_user:piddy_secure_password@localhost:5432/piddy_combined
NOTIFICATION_DATABASE_URL=postgresql://piddy_user:piddy_secure_password@localhost:5432/piddy_combined

# PostgreSQL direct connection
POSTGRES_USER=piddy_user
POSTGRES_PASSWORD=piddy_secure_password
POSTGRES_DB=piddy_combined
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ========================================
# Redis Configuration
# ========================================
REDIS_URL=redis://:piddy_redis_password@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=piddy_redis_password
REDIS_DB=0

# ========================================
# JWT & Authentication
# ========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ========================================
# Email Service Configuration
# ========================================

# SendGrid (Primary Email Provider)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# SMTP Configuration (Fallback Provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
# For Gmail: Use "App Passwords" (not your regular password)
# See: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-specific-password
SMTP_USE_TLS=true

# ========================================
# Environment & Deployment
# ========================================
ENV=production
# Options: development, staging, production
DEBUG=false

# ========================================
# API Configuration
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
NOTIFICATION_API_PORT=8001

# ========================================
# Rate Limiting (in requests per minute)
# ========================================
LOGIN_RATE_LIMIT=5
REGISTER_RATE_LIMIT=3
READ_RATE_LIMIT=100
WRITE_RATE_LIMIT=50
DELETE_RATE_LIMIT=10
ADMIN_RATE_LIMIT=1000

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ========================================
# CORS & Security
# ========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# For production: comma-separated list of your domains
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization

# ========================================
# Docker & Container Configuration
# ========================================
COMPOSE_PROJECT_NAME=piddy
DOCKER_NETWORK=piddy_network

# ========================================
# Backup & Monitoring
# ========================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
MONITORING_ENABLED=true
METRICS_PORT=9090

# ========================================
# Feature Flags (for future expansion)
# ========================================
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_WEBHOOKS=false
ENABLE_KAFKA_INTEGRATION=false
